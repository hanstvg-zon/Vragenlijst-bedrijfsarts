{
  "name": "vragenlijst-bedrijfsarts-frontend",
  "version": "1.0.0",
  "description": "Frontend for Vragenlijst Bedrijfsarts questionnaire system",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.1",
    "axios": "^1.6.5",
    "react-hook-form": "^7.48.1",
    "react-hot-toast": "^2.4.1",
    "zustand": "^4.4.7",
    "crypto-js": "^4.2.0",
    "react-progress-bar": "^6.4.0",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "framer-motion": "^10.16.4"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@types/node": "^20.10.4",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.5",
    "cypress": "^13.6.2",
    "eslint": "^8.53.0",
    "eslint-config-react-app": "^7.0.1",
    "prettier": "^3.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false",
    "test:e2e": "cypress open",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --check src",
    "format:fix": "prettier --write src",
    "type-check": "tsc --noEmit"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
